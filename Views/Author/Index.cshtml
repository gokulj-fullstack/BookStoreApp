@model IEnumerable<BookStoreApp.Models.Author>

@{
    ViewData["Title"] = "Authors";
}

<div class="container mt-4">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0">👨‍💼 Author Management</h2>
            <small class="text-muted">Manage all authors easily</small>
        </div>
        <a asp-action="Create" class="btn btn-primary shadow-sm">
            ➕ Add Author
        </a>
    </div>

    <!-- Search -->
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <input type="text" id="searchInput" class="form-control"
                   placeholder="🔍 Search authors..." onkeyup="searchAuthors()" />
        </div>
    </div>

    <!-- Table -->
    <div class="card shadow border-0">
        <div class="card-body p-0">

            <table class="table table-hover align-middle mb-0" id="authorTable">
                <thead class="table-dark">
                    <tr>
                        <th>👤 Name</th>
                        <th>📝 Biography</th>
                        <th class="text-center">⚙️ Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <span class="fw-semibold">@item.Name</span>
                            </td>

                            <td>
                                <span class="text-muted">
                                    @(item.Biography?.Length > 50 
                                        ? item.Biography.Substring(0, 50) + "..." 
                                        : item.Biography)
                                </span>
                            </td>

                            <td class="text-center">
                                <a asp-action="Edit" asp-route-id="@item.Id"
                                   class="btn btn-sm btn-warning me-1">✏️</a>

                                <a asp-action="Details" asp-route-id="@item.Id"
                                   class="btn btn-sm btn-info me-1">ℹ️</a>

                                <a asp-action="Delete" asp-route-id="@item.Id"
                                   class="btn btn-sm btn-danger">🗑️</a>
                            </td>
                        </tr>
                    }
                </tbody>

            </table>

        </div>
    </div>

</div>

<!-- SEARCH SCRIPT -->
<script>
    function searchAuthors() {
        let input = document.getElementById("searchInput").value.toLowerCase();
        let rows = document.querySelectorAll("#authorTable tbody tr");

        rows.forEach(row => {
            let text = row.innerText.toLowerCase();
            row.style.display = text.includes(input) ? "" : "none";
        });
    }
</script>