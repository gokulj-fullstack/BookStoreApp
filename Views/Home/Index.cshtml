@{
    ViewData["Title"] = "Home";
}

<!-- HERO SECTION -->
<div class="text-center py-5 bg-light rounded shadow-sm">
    <h1 class="display-4 fw-bold">📚 BookStore Dashboard</h1>
    <p class="lead">Manage your books and authors efficiently</p>
</div>

<!-- STATS SECTION -->
<div class="row mt-4 text-center">

    <div class="col-md-6">
        <div class="card shadow border-0">
            <div class="card-body">
                <h5 class="text-muted">Total Authors</h5>
                <h2 class="fw-bold text-primary">@ViewBag.AuthorCount</h2>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card shadow border-0">
            <div class="card-body">
                <h5 class="text-muted">Total Books</h5>
                <h2 class="fw-bold text-success">@ViewBag.BookCount</h2>
            </div>
        </div>
    </div>

</div>

<!-- ACTION CARDS -->
<div class="row mt-4">

    <div class="col-md-6">
        <div class="card shadow-lg border-0">
            <div class="card-body text-center">
                <h3>👨‍💼 Authors</h3>
                <p>Manage all authors in the system</p>
                <a href="/Author" class="btn btn-primary px-4">Manage Authors</a>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card shadow-lg border-0">
            <div class="card-body text-center">
                <h3>📖 Books</h3>
                <p>Manage books and assign authors</p>
                <a href="/Book" class="btn btn-success px-4">Manage Books</a>
            </div>
        </div>
    </div>

</div>